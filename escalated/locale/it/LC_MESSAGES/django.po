msgstr "Accedi per visualizzare tutti i dettagli del tuo ticket."

msgid "SLA Breach Alert"
msgstr "Avviso violazione SLA"

msgid "Breach Type:"
msgstr "Tipo di violazione:"

msgid "Assigned To:"
msgstr "Assegnato a:"

