msgstr "تم تقييم هذه التذكرة بالفعل."

msgid "Rating must be between 1 and 5."
msgstr "يجب أن يكون التقييم بين 1 و 5."

msgid "Invalid rating value."
msgstr "قيمة تقييم غير صالحة."

